{
  "main": "src/web/server.js",
  "scripts": {
    "build": "npx vite build --config client/vite.config.ts",
    "start": "for pid in $(ps aux | grep 'node src/web/server' | grep -v grep | awk '{print $2}'); do kill -9 $pid 2>/dev/null; done; ss -tlnp 'sport = :5001' 2>/dev/null | grep -oP 'pid=\\K[0-9]+' | xargs -r kill -9 2>/dev/null; ss -tlnp 'sport = :5000' 2>/dev/null | grep -oP 'pid=\\K[0-9]+' | xargs -r kill -9 2>/dev/null; sleep 2; node src/db/pg-init.js; npx concurrently --names \"api,ui\" \"PORT=5001 node src/web/server.js\" \"npx vite --config client/vite.config.ts\"",
    "bot": "node src/bot/register-pilates.js",
    "db:test": "node src/db/test-jobs.js",
    "bot:db": "node src/bot/run-from-db.js",
    "scheduler:test": "node src/scheduler/test-booking-window.js",
    "scheduler:once": "node src/scheduler/run-scheduler-once.js",
    "scheduler:run": "node src/scheduler/run-eligible-jobs-once.js",
    "db:add": "node src/db/add-job.js",
    "db:create-test-job": "node src/db/create-test-job.js",
    "db:cleanup-test-jobs": "node src/db/cleanup-test-jobs.js",
    "scheduler:loop": "node src/scheduler/run-scheduler-loop.js",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.4"
  }
}
